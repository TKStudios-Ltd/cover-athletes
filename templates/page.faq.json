                  "blocks": {
                    "text_QLndcQ": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Testing involved current and former professional cricketers, coaches and high-performance environments. Their feedback directly informed refinements around comfort, fit, stability and movement.</p>",
