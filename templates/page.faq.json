                },
                "accordion_row_YgUdfW": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Can Core Cover be machine washed or submerged?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_y6bNhL": {
                      "type": "text",
                      "settings": {
                        "text": "<p>No. Cover should not be machine washed, submerged in water or exposed to high heat, as this may compromise material integrity.</p>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "custom",
                        "font": "var(--font-body--family)",
