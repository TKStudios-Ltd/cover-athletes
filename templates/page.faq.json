                  "blocks": {
                    "text_6TD9cK": {
                      "type": "text",
                      "settings": {
                        "text": "<p>After each use, towel dry thoroughly to remove moisture. For hygiene purposes, it may occasionally be wiped down with isopropyl alcohol.</p>",
