{% comment %}
Testimonial Column Slider
{% endcomment %}

<section
  class="rd-slider testimonial-column-slider testimonial-column-slider-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-delay="{{ section.settings.delay }}"
>
  <div
    class="rd-slider__inner testimonial-column-slider__inner"
    style="
      --pad-top: {{ section.settings.padding_top }}px;
      --pad-bottom: {{ section.settings.padding_bottom }}px;
    "
  >
    <div class="swiper rd-swiper testimonial-swiper" id="RDSlider-{{ section.id }}">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div
            class="swiper-slide testimonial-slide color-{{ section.settings.color_scheme }}"
            {{ block.shopify_attributes }}
          >
            <div class="testimonial-card">
              {% if block.settings.testimonial != blank %}
                <div class="testimonial-card__text rte">
                  {{ block.settings.testimonial }}
                </div>
              {% endif %}

              <div class="testimonial-card__footer">
                {% if block.settings.name != blank %}
                  <div class="testimonial-card__name">
                    {{ block.settings.name }}
                  </div>
                {% endif %}

                <div class="testimonial-card__avatar">
                  {% if block.settings.headshot != blank %}
                    {{
                      block.settings.headshot
                      | image_url: width: 120
                      | image_tag:
                        loading: 'lazy',
                        widths: '60, 90, 120',
                        class: 'testimonial-card__avatar-image'
                    }}
                  {% else %}
                    <span class="testimonial-card__quote-icon" aria-hidden="true">
                      {{- 'icon-quote.svg' | inline_asset_content -}}
                    </span>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    {% if section.settings.show_arrows %}
      <div class="testimonial-column-slider__nav">
        <button
          type="button"
          class="testimonial-column-slider__arrow testimonial-column-slider__arrow--prev"
          aria-label="Previous slide"
        >
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M14.5 6.5L9 12L14.5 17.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <button
          type="button"
          class="testimonial-column-slider__arrow testimonial-column-slider__arrow--next"
          aria-label="Next slide"
        >
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M9.5 6.5L15 12L9.5 17.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .testimonial-column-slider {
    width: 100%;
  }

  .testimonial-column-slider__inner {
    padding-top: var(--pad-top);
    padding-bottom: var(--pad-bottom);
    position: relative;
  }

  .testimonial-swiper {
    padding-left: 20px;
    overflow: visible;
  }

  .testimonial-swiper,
  .testimonial-swiper .testimonial-slide,
  .testimonial-swiper .testimonial-card {
    cursor: url("{{ 'cursor-drag.svg' | asset_url }}") 20 20, grab !important;
  }

  .testimonial-swiper:active,
  .testimonial-swiper:active * {
    cursor: grabbing !important;
  }

  .testimonial-swiper .swiper-wrapper {
    display: flex;
  }

  .testimonial-swiper .swiper-slide {
    flex-shrink: 0;
  }

  .testimonial-slide {
    width: calc(30% - 20px);
  }

  @media (min-width: 990px) and (max-width: 1199px) {
    .testimonial-slide {
      width: calc(35% - 20px);
    }
  }

  @media (min-width: 750px) and (max-width: 989px) {
    .testimonial-slide {
      width: calc(45% - 20px);
    }
  }

  @media (max-width: 749px) {
    .testimonial-slide {
      width: calc(82% - 20px);
    }
  }

  .testimonial-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 250px;
    height: 100%;
    padding: 26px 20px 20px;
    border-radius: 8px;
    background: linear-gradient(135deg, #5b5b5b 0%, #3f3f3f 100%);
    color: #ffffff;
    overflow: hidden;
  }

  .testimonial-card__text {
    margin-bottom: 28px;
  }

  .testimonial-card__text,
  .testimonial-card__text p {
    font-size: 15px;
    line-height: 1.28;
    font-weight: 300;
    color: #ffffff;
    margin-top: 0;
  }

  .testimonial-card__text p:last-child {
    margin-bottom: 0;
  }

  .testimonial-card__footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-top: auto;
  }

  .testimonial-card__name {
    font-size: 14px;
    line-height: 1.3;
    color: rgba(255, 255, 255, 0.82);
  }

  .testimonial-card__avatar {
    width: 42px;
    height: 42px;
    min-width: 42px;
    border-radius: 50%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.12);
  }

  .testimonial-card__avatar-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .testimonial-card__quote-icon {
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #00e68a;
  }

  .testimonial-card__quote-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .testimonial-column-slider__nav {
    display: flex;
    gap: 8px;
    margin-top: 22px;
    padding-left: 20px;
  }

  .testimonial-column-slider__arrow {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid rgba(var(--color-foreground), 0.15);
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    cursor: pointer;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .testimonial-column-slider__arrow:hover {
    opacity: 0.8;
  }

  .testimonial-column-slider__arrow:active {
    transform: scale(0.97);
  }

  .testimonial-column-slider__arrow svg {
    width: 18px;
    height: 18px;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll('.rd-slider').forEach(section => {
      const id = section.dataset.sectionId;
      const sliderEl = section.querySelector('#RDSlider-' + id);
      if (!sliderEl) return;

      const autoplay = section.dataset.autoplay === "true";
      const delay = parseInt(section.dataset.delay || 5) * 1000;
      const prevBtn = section.querySelector('.testimonial-column-slider__arrow--prev');
      const nextBtn = section.querySelector('.testimonial-column-slider__arrow--next');

      new Swiper(sliderEl, {
        slidesPerView: "auto",
        spaceBetween: 20,
        speed: 600,
        grabCursor: true,
        autoplay: autoplay ? { delay, pauseOnMouseEnter: true } : false,
        navigation: prevBtn && nextBtn ? {
          prevEl: prevBtn,
          nextEl: nextBtn
        } : false
      });
    });
  });
</script>

{% schema %}
{
  "name": "Testimonial slider",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 5,
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "delay",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Autoplay delay (sec)",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "richtext",
          "id": "testimonial",
          "label": "Testimonial"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "image_picker",
          "id": "headshot",
          "label": "Headshot"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial Column Slider",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}