{% comment %}
Testimonial Column Slider
{% endcomment %}

<section
  class="rd-slider testimonial-column-slider testimonial-column-slider-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-delay="{{ section.settings.delay }}"
  style="background: #FFFFFF !important;"
>
  <div
    class="rd-slider__inner testimonial-column-slider__inner"
    style="
      --pad-top: {{ section.settings.padding_top }}px;
      --pad-bottom: {{ section.settings.padding_bottom }}px;
    "
  >
    <div class="swiper rd-swiper testimonial-swiper" id="RDSlider-{{ section.id }}">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div
            class="swiper-slide testimonial-slide color-{{ section.settings.color_scheme }}"
            {{ block.shopify_attributes }}
          >
            <div class="testimonial-card">
              {% if block.settings.testimonial != blank %}
                <div class="testimonial-card__text rte">
                  {{ block.settings.testimonial }}
                </div>
              {% endif %}

              <div class="testimonial-card__footer">
                {% if block.settings.name != blank %}
                  <div class="testimonial-card__name">
                    {{ block.settings.name }}
                  </div>
                {% endif %}

                {% if block.settings.headshot != blank %}
                  <div class="testimonial-card__avatar">
                    {{
                      block.settings.headshot
                      | image_url: width: 120
                      | image_tag:
                        loading: 'lazy',
                        widths: '60, 90, 120',
                        class: 'testimonial-card__avatar-image'
                    }}
                  </div>
                {% else %}
                  <img
                    src="https://cdn.shopify.com/s/files/1/0770/7341/6435/files/Cover_Quote-Icon.svg"
                    alt=""
                    loading="lazy"
                    class="testimonial-card__quote-icon"
                  >
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<style>
    .testimonial-column-slider {
        width: 100%;
    }
    .testimonial-column-slider__inner {
        padding-top: var(--pad-top);
        padding-bottom: var(--pad-bottom);
        position: relative;
    }
    .testimonial-swiper {
        padding-left: 20px;
        overflow: visible;
    }
    .testimonial-swiper,
    .testimonial-swiper .testimonial-slide,
    .testimonial-swiper .testimonial-card {
        cursor: url("{{ 'cursor-drag.svg' | asset_url }}") 20 20, grab !important;
    }
    .testimonial-swiper:active,
    .testimonial-swiper:active * {
        cursor: grabbing !important;
    }
    .testimonial-swiper .swiper-wrapper {
        display: flex;
        align-items: flex-start;
    }
    .testimonial-swiper .swiper-slide {
        flex-shrink: 0;
        height: auto;
    }
    .testimonial-slide {
        width: calc(30% - 20px);
    }
    @media (min-width: 990px) and (max-width: 1199px) {
        .testimonial-slide {
            width: calc(35% - 20px);
        }
    }
    @media (min-width: 750px) and (max-width: 989px) {
        .testimonial-slide {
            width: calc(45% - 20px);
        }
    }
    @media (max-width: 749px) {
        .testimonial-slide {
            width: calc(82% - 20px);
        }
        .testimonial-card {
            padding: 20px !important;
        }
        .testimonial-card__text p {
            font-size: 20px !important;
        }
        .testimonial-card__footer {
            margin-top: 50px !important;
        }
        .testimonial-card__name {
            font-size: 16px !important;
        }
        .testimonial-card__quote-icon {
            width: 32px !important;
        }
        .testimonial-card__avatar {
            width: 54px !important;
            height: 54px !important;
        }
    }
    .testimonial-card {
        position: relative;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        height: auto;
        padding: 25px;
        border-radius: 10px;
        background: linear-gradient(135deg, #5b5b5b 0%, #3f3f3f 100%);
        color: #FFFFFF;
        overflow: hidden;
    }
    .testimonial-card__text,
    .testimonial-card__text p {
        font-family: "Graphik", sans-serif !important;
        font-size: 26px;
        letter-spacing: -1px;
        line-height: 1.2;
        font-weight: 300;
        color: #FFFFFF;
        margin-top: 0;
    }
    .testimonial-card__text p:last-child {
        margin-bottom: 0;
    }
    .testimonial-card__footer {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 20px;
        margin-top: 80px;
    }
    .testimonial-card__name {
        font-family: "Graphik", sans-serif !important;
        font-size: 18px;
        letter-spacing: -1px;
        line-height: 1.2;
        font-weight: 300;
        color: #FFFFFF;
    }
    .testimonial-card__avatar {
        width: 70px;
        height: 70px;
        min-width: 42px;
        overflow: hidden;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .testimonial-card__avatar-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        border-radius: 50%;
    }
    .testimonial-card__quote-icon {
        width: 44px;
        height: auto;
        display: block;
        flex-shrink: 0;
    }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll('.rd-slider').forEach(section => {
      const id = section.dataset.sectionId;
      const sliderEl = section.querySelector('#RDSlider-' + id);
      if (!sliderEl) return;

      const autoplay = section.dataset.autoplay === "true";
      const delay = parseInt(section.dataset.delay || 5) * 1000;

      new Swiper(sliderEl, {
        slidesPerView: "auto",
        spaceBetween: 20,
        speed: 600,
        grabCursor: true,
        autoHeight: false,
        autoplay: autoplay ? { delay, pauseOnMouseEnter: true } : false
      });
    });
  });
</script>

{% schema %}
{
  "name": "Testimonial slider",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 5,
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "delay",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Autoplay delay (sec)",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "richtext",
          "id": "testimonial",
          "label": "Testimonial"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "image_picker",
          "id": "headshot",
          "label": "Headshot"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial Column Slider",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}