{% comment %}
  Popup Cover
  Supports:
  - Promotional popup
  - Newsletter popup
{% endcomment %}

{%- liquid
  assign is_test_page = false
  if request.path == '/pages/privacy-policy'
    assign is_test_page = true
  endif

  assign should_render = true

  unless is_test_page
    if section.settings.hide_on_mobile and request.design_mode == false
      if request.user_agent contains 'Mobile' or request.user_agent contains 'Android'
        assign should_render = false
      endif
    endif

    if section.settings.exclude_paths != blank and request.design_mode == false
      assign current_path = request.path | downcase
      assign lines = section.settings.exclude_paths | newline_to_br | split: '<br />'
      for l in lines
        assign p = l | strip | downcase
        if p != blank and current_path contains p
          assign should_render = false
        endif
      endfor
    endif
  endunless
-%}

{%- if should_render -%}
  <div
    id="PopupCover-{{ section.id }}"
    class="popup-cover popup-cover--{{ section.settings.popup_type }}"
    data-delay="{{ section.settings.show_delay_ms }}"
    data-hide-days="{{ section.settings.hide_days }}"
    data-scroll="{{ section.settings.trigger_scroll_percent }}"
    data-exit="{{ section.settings.enable_exit_intent }}"
    data-session="{{ section.settings.once_per_session }}"
    data-key="popup_cover_{{ section.id }}"
    style="display:none;"
  >
    <div class="popup-cover__scrim" aria-hidden="true"></div>

    <div
      class="popup-cover__wrap"
      role="dialog"
      aria-modal="true"
      aria-label="{{ section.settings.heading | strip_html | escape }}"
    >
      <div class="popup-cover__card color-{{ section.settings.color_scheme }}">
        <button class="popup-cover__close" type="button" aria-label="Close popup">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 6L18 18M18 6L6 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>

        <div class="popup-cover__glow"></div>

        <div class="popup-cover__inner">
          <div class="popup-cover__left">
            {% if section.settings.heading != blank %}
              <h2 class="popup-cover__heading">
                {{ section.settings.heading }}
              </h2>
            {% endif %}

            {% if section.settings.subheading != blank %}
              <div class="popup-cover__subheading">
                {{ section.settings.subheading }}
              </div>
            {% endif %}

            {% if section.settings.popup_type == 'promotional' %}
              {% if section.settings.button_label != blank and section.settings.button_link != blank %}
                <a href="{{ section.settings.button_link }}" class="popup-cover__button">
                  {{ section.settings.button_label }}
                </a>
              {% endif %}

              {% if section.settings.fine_print != blank %}
                <div class="popup-cover__fine-print">
                  {{ section.settings.fine_print }}
                </div>
              {% endif %}
            {% endif %}
          </div>

          <div class="popup-cover__right">
            {% if section.settings.popup_type == 'promotional' %}
              {% if section.settings.image != blank %}
                <div class="popup-cover__image-wrap">
                  {{
                    section.settings.image
                    | image_url: width: 1200
                    | image_tag:
                      loading: 'lazy',
                      class: 'popup-cover__image'
                  }}
                </div>
              {% endif %}
            {% endif %}

            {% if section.settings.popup_type == 'newsletter' %}
              {%- assign popup_form_id = 'PopupCoverForm-' | append: section.id -%}
              {% form 'contact', id: popup_form_id, class: 'popup-cover__form' %}
                {% if form.posted_successfully? %}
                  <div class="popup-cover__success">
                    {{ section.settings.success_message }}
                  </div>
                {% else %}
                  {% if form.errors %}
                    <div class="popup-cover__errors">
                      {{ form.errors | default_errors }}
                    </div>
                  {% endif %}

                  <input type="hidden" name="contact[tags]" value="popup-newsletter">

                  <div class="popup-cover__fields">
                    <input
                      class="popup-cover__input"
                      type="text"
                      name="contact[name]"
                      placeholder="{{ section.settings.name_placeholder }}"
                      autocomplete="name"
                    >

                    <input
                      class="popup-cover__input"
                      type="email"
                      name="contact[email]"
                      placeholder="{{ section.settings.email_placeholder }}"
                      autocomplete="email"
                      required
                    >

                    <input
                      class="popup-cover__input"
                      type="tel"
                      name="contact[phone]"
                      placeholder="{{ section.settings.phone_placeholder }}"
                      autocomplete="tel"
                    >

                    <input
                      class="popup-cover__input"
                      type="text"
                      name="contact[company]"
                      placeholder="{{ section.settings.country_placeholder }}"
                    >

                    <input
                      class="popup-cover__input"
                      type="text"
                      name="contact[body]"
                      placeholder="{{ section.settings.hear_placeholder }}"
                    >
                  </div>

                  <button class="popup-cover__submit" type="submit">
                    {{ section.settings.submit_label }}
                  </button>
                {% endif %}
              {% endform %}

              {% if section.settings.privacy_text != blank %}
                <div class="popup-cover__privacy">
                  {{ section.settings.privacy_text }}
                </div>
              {% endif %}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    #PopupCover-{{ section.id }} {
      position: fixed;
      inset: 0;
      z-index: 999;
      display: none;
    }

    #PopupCover-{{ section.id }}.is-visible {
      display: block;
    }

    #PopupCover-{{ section.id }} .popup-cover__scrim {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    }

    #PopupCover-{{ section.id }} .popup-cover__wrap {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    #PopupCover-{{ section.id }} .popup-cover__card {
      position: relative;
      width: min(100%, 860px);
      border-radius: 22px;
      overflow: hidden;
      background: rgba(18, 18, 18, 0.78);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.18);
      box-shadow: 0 20px 80px rgba(0, 0, 0, 0.45);
    }

    #PopupCover-{{ section.id }} .popup-cover__glow {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 8% 55%, rgba(13, 220, 170, 0.28), transparent 26%),
        radial-gradient(circle at 42% 25%, rgba(80, 120, 255, 0.18), transparent 24%),
        radial-gradient(circle at 88% 100%, rgba(255, 115, 0, 0.16), transparent 24%);
      opacity: 0.95;
    }

    #PopupCover-{{ section.id }} .popup-cover__card::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      border-radius: 22px;
      padding: 1px;
      background: linear-gradient(
        135deg,
        rgba(126, 145, 255, 0.55),
        rgba(255, 255, 255, 0.12) 45%,
        rgba(13, 220, 170, 0.55)
      );
      -webkit-mask:
        linear-gradient(#000 0 0) content-box,
        linear-gradient(#000 0 0);
      -webkit-mask-composite: xor;
              mask-composite: exclude;
    }

    #PopupCover-{{ section.id }} .popup-cover__close {
      position: absolute;
      top: 16px;
      right: 16px;
      width: 40px;
      height: 40px;
      border: 0;
      border-radius: 999px;
      background: transparent;
      color: rgba(255,255,255,0.9);
      cursor: pointer;
      z-index: 5;
    }

    #PopupCover-{{ section.id }} .popup-cover__close svg {
      width: 20px;
      height: 20px;
      display: block;
      margin: auto;
    }

    #PopupCover-{{ section.id }} .popup-cover__inner {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      padding: 38px 28px 28px;
      min-height: 440px;
    }

    #PopupCover-{{ section.id }} .popup-cover__left {
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      padding-right: 8px;
    }

    #PopupCover-{{ section.id }} .popup-cover__right {
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    #PopupCover-{{ section.id }} .popup-cover__heading {
      margin: 0;
      color: #fff;
      font-size: clamp(34px, 4vw, 60px);
      line-height: 0.95;
      font-weight: 400;
      letter-spacing: -0.03em;
      max-width: 420px;
    }

    #PopupCover-{{ section.id }} .popup-cover__subheading {
      margin-top: 14px;
      color: rgba(255,255,255,0.52);
      font-size: clamp(24px, 3.2vw, 38px);
      line-height: 1.08;
      font-weight: 400;
      max-width: 420px;
    }

    #PopupCover-{{ section.id }} .popup-cover__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 190px;
      min-height: 54px;
      margin-top: 44px;
      padding: 0 28px;
      border-radius: 999px;
      background: linear-gradient(90deg, #45f0a8 0%, #49e6b7 100%);
      color: #111;
      font-size: 24px;
      line-height: 1;
      text-decoration: none;
      font-weight: 500;
    }

    #PopupCover-{{ section.id }} .popup-cover__fine-print {
      margin-top: auto;
      padding-top: 22px;
      color: rgba(255,255,255,0.58);
      font-size: 12px;
      line-height: 1.35;
      max-width: 360px;
    }

    #PopupCover-{{ section.id }} .popup-cover__image-wrap {
      border-radius: 14px;
      overflow: hidden;
      background: #000;
      aspect-ratio: 1 / 1;
      width: 100%;
      max-width: 380px;
      margin-left: auto;
    }

    #PopupCover-{{ section.id }} .popup-cover__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    #PopupCover-{{ section.id }} .popup-cover__form {
      width: 100%;
      margin-top: 6px;
    }

    #PopupCover-{{ section.id }} .popup-cover__fields {
      display: grid;
      gap: 12px;
    }

    #PopupCover-{{ section.id }} .popup-cover__input {
      width: 100%;
      min-height: 54px;
      padding: 0 18px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.85);
      background: transparent;
      color: #fff;
      font-size: 16px;
      outline: none;
      box-shadow: none;
    }

    #PopupCover-{{ section.id }} .popup-cover__input::placeholder {
      color: rgba(255,255,255,0.92);
      opacity: 1;
    }

    #PopupCover-{{ section.id }} .popup-cover__submit {
      width: 100%;
      min-height: 54px;
      margin-top: 14px;
      border: 0;
      border-radius: 999px;
      background: #e9e9e9;
      color: #111;
      font-size: 18px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      cursor: pointer;
    }

    #PopupCover-{{ section.id }} .popup-cover__privacy {
      margin-top: auto;
      padding-top: 34px;
      color: rgba(255,255,255,0.82);
      font-size: 12px;
      line-height: 1.45;
      max-width: 420px;
    }

    #PopupCover-{{ section.id }} .popup-cover__privacy a {
      color: inherit;
      text-decoration: underline;
    }

    #PopupCover-{{ section.id }} .popup-cover__success,
    #PopupCover-{{ section.id }} .popup-cover__errors {
      color: #fff;
      font-size: 14px;
      line-height: 1.5;
    }

    @media screen and (max-width: 989px) {
      #PopupCover-{{ section.id }} .popup-cover__inner {
        grid-template-columns: 1fr;
        gap: 28px;
        min-height: auto;
      }

      #PopupCover-{{ section.id }} .popup-cover__left,
      #PopupCover-{{ section.id }} .popup-cover__right {
        padding-right: 0;
      }

      #PopupCover-{{ section.id }} .popup-cover__image-wrap {
        max-width: 100%;
        margin-left: 0;
      }

      #PopupCover-{{ section.id }} .popup-cover__fine-print,
      #PopupCover-{{ section.id }} .popup-cover__privacy {
        margin-top: 20px;
        padding-top: 0;
      }
    }

    @media screen and (max-width: 749px) {
      #PopupCover-{{ section.id }} .popup-cover__wrap {
        padding: 16px;
      }

      #PopupCover-{{ section.id }} .popup-cover__inner {
        padding: 24px 18px 20px;
      }

      #PopupCover-{{ section.id }} .popup-cover__heading {
        font-size: 40px;
      }

      #PopupCover-{{ section.id }} .popup-cover__subheading {
        font-size: 24px;
      }

      #PopupCover-{{ section.id }} .popup-cover__button,
      #PopupCover-{{ section.id }} .popup-cover__input,
      #PopupCover-{{ section.id }} .popup-cover__submit {
        min-height: 50px;
      }
    }
  </style>

  <script>
    (function() {
      var root = document.getElementById('PopupCover-{{ section.id }}');
      if (!root) return;

      var DELAY_MS = {{ section.settings.show_delay_ms | default: 1200 }};
      var HIDE_DAYS = {{ section.settings.hide_days | default: 14 }};
      var TRIGGER_SCROLL = {{ section.settings.trigger_scroll_percent | default: 0 }};
      var USE_EXIT = {{ section.settings.enable_exit_intent | json }};
      var ONCE_PER_SESSION = {{ section.settings.once_per_session | json }};
      var KEY = root.dataset.key;

      function now() { return Date.now(); }
      function ms(days) { return days * 24 * 60 * 60 * 1000; }

      function getStore() {
        try { return window.localStorage; } catch(e) { return null; }
      }

      var store = getStore();

      function hiddenUntil() {
        if (!store) return 0;
        var v = store.getItem(KEY);
        return v ? parseInt(v, 10) : 0;
      }

      function hideForDays(days) {
        if (!store) return;
        store.setItem(KEY, String(now() + ms(days)));
      }

      function hideForSession() {
        try { sessionStorage.setItem(KEY + '_s', '1'); } catch(e) {}
      }

      function isSessionHidden() {
        try { return sessionStorage.getItem(KEY + '_s') === '1'; } catch(e) { return false; }
      }

      function markHidden() {
        if (ONCE_PER_SESSION) hideForSession();
        else if (HIDE_DAYS > 0) hideForDays(HIDE_DAYS);
      }

      function canShow() {
        if (window.location.pathname === '/pages/privacy-policy') return true;
        if (window.Shopify && Shopify.designMode) return true;
        if (ONCE_PER_SESSION && isSessionHidden()) return false;
        return now() > hiddenUntil();
      }

      function show() {
        if (root.classList.contains('is-visible')) return;
        root.style.display = 'block';
        root.classList.add('is-visible');
      }

      function hide() {
        root.classList.remove('is-visible');
        root.style.display = 'none';
        markHidden();
      }

      function scheduleShow() {
        if (!canShow()) return;

        var scheduled = false;

        function schedule() {
          if (scheduled) return;
          scheduled = true;
          setTimeout(show, DELAY_MS);
        }

        if (USE_EXIT && window.innerWidth > 989) {
          document.addEventListener('mouseout', function onExit(e) {
            if (e.clientY <= 0) {
              schedule();
              document.removeEventListener('mouseout', onExit);
            }
          });
        }

        if (TRIGGER_SCROLL > 0) {
          window.addEventListener('scroll', function onScroll() {
            var doc = document.documentElement;
            var denom = (doc.scrollHeight - window.innerHeight) || 1;
            var scrolled = ((window.scrollY || doc.scrollTop) / denom) * 100;
            if (scrolled >= TRIGGER_SCROLL) {
              schedule();
              window.removeEventListener('scroll', onScroll);
            }
          }, { passive: true });
        }

        if (window.location.pathname === '/pages/privacy-policy') {
            show();
            return;
        }

        if (!USE_EXIT && TRIGGER_SCROLL <= 0) {
            setTimeout(show, DELAY_MS);
        }
      }

      var closeBtn = root.querySelector('.popup-cover__close');
      if (closeBtn) closeBtn.addEventListener('click', hide);

      var scrim = root.querySelector('.popup-cover__scrim');
      if (scrim) scrim.addEventListener('click', hide);

      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && root.classList.contains('is-visible')) {
          hide();
        }
      });

      setTimeout(scheduleShow, 0);
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Popup",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "popup_type",
      "label": "Popup type",
      "options": [
        { "value": "promotional", "label": "Promotional" },
        { "value": "newsletter", "label": "Newsletter" }
      ],
      "default": "promotional"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Promotional image"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "30 day trial. Free returns."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>No risk, just better protection. If it doesn’t perform, send it back.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Promotional button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Promotional button link"
    },
    {
      "type": "richtext",
      "id": "fine_print",
      "label": "Promotional fine print",
      "default": "<p>30 day trial valid on first purchase. Items must be returned within 30 days in good condition. Click here for full terms.</p>"
    },
    {
      "type": "text",
      "id": "name_placeholder",
      "label": "Name placeholder",
      "default": "Full Name"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "phone_placeholder",
      "label": "Phone placeholder",
      "default": "Mobile Phone Number"
    },
    {
      "type": "text",
      "id": "country_placeholder",
      "label": "Country placeholder",
      "default": "Country"
    },
    {
      "type": "text",
      "id": "hear_placeholder",
      "label": "How did you hear about us placeholder",
      "default": "How did you hear about us?"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Submit"
    },
    {
      "type": "richtext",
      "id": "privacy_text",
      "label": "Newsletter privacy text",
      "default": "<p>Cover needs the contact information you provide to us to contact you about our products and services. You may unsubscribe from these communications at any time. For information on how to unsubscribe, as well as our privacy practices and commitment to protecting your privacy, please review our Privacy Policy.</p>"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thanks for signing up."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50,
      "unit": "%"
    },
    {
      "type": "number",
      "id": "show_delay_ms",
      "label": "Delay before showing (ms)",
      "default": 1000
    },
    {
      "type": "number",
      "id": "trigger_scroll_percent",
      "label": "Show after scroll % (0 to disable)",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "enable_exit_intent",
      "label": "Show on exit intent",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "once_per_session",
      "label": "Only show once per session",
      "default": false
    },
    {
      "type": "range",
      "id": "hide_days",
      "label": "Hide for days after closing",
      "min": 0,
      "max": 90,
      "step": 1,
      "default": 14
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": false
    },
    {
      "type": "textarea",
      "id": "exclude_paths",
      "label": "Exclude on URL paths (one per line)",
      "default": "/cart\n/checkout\n/account"
    }
  ],
  "presets": [
    {
      "name": "Popup"
    }
  ]
}
{% endschema %}